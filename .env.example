# Supabase (added in Phase 1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (added in Phase 6). Unset = disabled, no error reporting (see
# sentry.*.config.ts). SENTRY_AUTH_TOKEN/ORG/PROJECT are only needed for
# source map upload in CI, not for error capture itself.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Playwright E2E (added in Phase 6) — two real, already-confirmed test
# accounts; see e2e/README.md. Skipped if unset.
TEST_CREATOR_EMAIL=
TEST_CREATOR_PASSWORD=
TEST_CLIENT_EMAIL=
TEST_CLIENT_PASSWORD=
